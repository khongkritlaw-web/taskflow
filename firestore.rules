rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Validate custom ID path parameters
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User collection rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // profiles are permanent

      function incoming() {
        return request.resource.data;
      }
      
      // 2. Tasks sub-collection rules
      match /tasks/{taskId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(taskId);
        allow delete: if isOwner(userId);
      }

      // 3. Expenses sub-collection rules
      match /expenses/{expenseId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(expenseId);
        allow delete: if isOwner(userId);
      }

      // 4. Settings sub-collection rules (e.g. app settings)
      match /settings/app {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }
    }
  }
}
